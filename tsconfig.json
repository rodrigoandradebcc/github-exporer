{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@expo/vector-icons": [
        "node_modules/expo/node_modules/@expo/vector-icons"
      ],
      "@expo/vector-icons/*": [
        "node_modules/expo/node_modules/@expo/vector-icons/*"
      ]
    },
    "types": [
      "jest"
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts"
  ]
}
